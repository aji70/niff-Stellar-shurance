{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testMatch": ["<rootDir>/e2e/**/*.e2e-spec.ts"],
  "transform": {
    "^.+\\.tsx?$": ["ts-jest", { "tsconfig": "../tsconfig.test.json" }]
  },
  "testEnvironment": "node",
  "globalSetup": "<rootDir>/global-setup.ts",
  "globalTeardown": "<rootDir>/global-teardown.ts",
  "testTimeout": 60000,
  "maxWorkers": 1,
  "forceExit": true
}
